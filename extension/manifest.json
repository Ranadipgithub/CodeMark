{
  "manifest_version": 3,
  "name": "CodeMark",
  "version": "1.0",
  "description": "Save LeetCode problems to your dashboard",
  "permissions": [
    "cookies",
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://leetcode.com/graphql"
  ],
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CodeMark",
    "default_icon": "logo.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
